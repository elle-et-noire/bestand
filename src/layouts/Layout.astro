---
import "../styles/globals.css";
import BackgroundPattern from "../components/BackgroundPattern.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Dispositif",
  description = "A personal blog featuring articles on mathematics and physics.",
} = Astro.props;
---

<!doctype html>
<html lang="ja" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* 本文＝Zen Maru Gothic medium、コード＝Fira Mono。どちらも自前ホスト（同一オリジン）の
        サブセット woff2（globals.css の @font-face）。本文フォントは全ページで最初に必要なので
        preload して、CSS 解析を待たずに転送を始める。 */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={`${import.meta.env.BASE_URL}/fonts/zen-maru-gothic-medium.woff2`}
      crossorigin="anonymous"
    />

    {/* 数式フォント (woff2) は @font-face 経由でこの CDN から読み込むため、接続を事前確立。 */}
    <link
      rel="preconnect"
      href="https://cdn.jsdelivr.net"
      crossorigin="anonymous"
    />

    {/* テーマの初期適用（FOUC 防止）。body 描画前に同期実行し、保存値→OS 設定の順で
        <html> に dark/light クラスを付ける。 */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          var d = t
            ? t === "dark"
            : matchMedia("(prefers-color-scheme: dark)").matches;
          var c = document.documentElement.classList;
          c.toggle("dark", d);
          c.toggle("light", !d);
        } catch (e) {}
      })();
    </script>

    {/* 記事ページ用：数式フォントの preload と CHTML スタイルを差し込む。 */}
    <slot name="head" />
  </head>
  <body>
    <BackgroundPattern />
    <main class="min-h-svh m-0 pb-12">
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
  }
</style>
