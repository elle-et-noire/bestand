---
import { ClientRouter } from "astro:transitions";
import "@styles/globals.css";
import BackgroundPattern from "@components/BackgroundPattern.astro";
import { withBase } from "@lib/base";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Bestand",
  description = "A personal blog featuring articles on mathematics and physics.",
} = Astro.props;
---

<!doctype html>
<html lang="ja" class="antialiased" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase("favicon.ico?v=2")} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg?v=2")} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* ページ遷移をクライアントサイドルーティングにする。これでフルページロードが消え、
        タブ・favicon・再読み込みボタンのちらつきがなくなる。 */}
    <ClientRouter />

    {/* 本文＝Zen Maru Gothic medium、コード＝Fira Mono。どちらも自前ホスト（同一オリジン）の
        サブセット woff2（globals.css の @font-face）。本文フォントは全ページで最初に必要なので
        preload して、CSS 解析を待たずに転送を始める。 */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={withBase("fonts/zen-maru-gothic-medium.woff2")}
      crossorigin="anonymous"
    />

    {/* テーマの初期適用（FOUC 防止）。body 描画前に同期実行し、保存値→OS 設定の順で
        <html> に dark/light クラスを付ける。ClientRouter のページ遷移では <html> の
        class が遷移先（dark/light 未設定）の内容で上書きされるため、astro:after-swap でも
        再適用してテーマが一瞬戻るのを防ぐ。 */}
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem("theme");
            var d = t
              ? t === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches;
            var c = document.documentElement.classList;
            c.toggle("dark", d);
            c.toggle("light", !d);
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    {/* 記事ページ用：数式フォントの preload と CHTML スタイルを差し込む。 */}
    <slot name="head" />
  </head>
  <body>
    <BackgroundPattern />
    <main class="min-h-svh m-0 pb-12">
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
  }
</style>
