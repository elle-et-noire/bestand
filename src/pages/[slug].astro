---
import Layout from "@layouts/Layout.astro";
import { getAllSlugs, getPostBySlug } from "@lib/post";
import { markdownToHtml } from "@lib/convert";
import { getHeadings } from "@lib/toc";
import { MATH_FONT_PRELOAD_HREF } from "@lib/mathjax";
import DateInfo from "@components/DateInfo.astro";
import Toc from "@components/Toc.astro";
import CloseButton from "@components/CloseButton.astro";
import CloseOverlay from "@components/CloseOverlay.astro";
import CloseSeal from "@components/CloseSeal.astro";
import ArticleInteractions from "@components/ArticleInteractions.astro";

// 記事の中身は getStaticPaths で読み、props としてページへ渡す（Astro のイディオム。
// params から slug を取り直して再読込する必要がなく、非 null アサートも要らない）。
export async function getStaticPaths() {
  return getAllSlugs().map((slug) => ({
    params: { slug },
    props: getPostBySlug(slug),
  }));
}

const { content, data } = Astro.props;
const { html, css } = await markdownToHtml(content);
const headings = getHeadings(content);
---

<Layout title={data.title}>
  {/* 数式のある記事だけ主フォントを先読みし、抽出した CHTML スタイルを <head> へ。 */}
  {
    css && (
      <Fragment slot="head">
        <link
          rel="preload"
          as="font"
          type="font/woff2"
          href={MATH_FONT_PRELOAD_HREF}
          crossorigin="anonymous"
        />
        <style is:inline set:html={css} />
      </Fragment>
    )
  }

  {/* グラスモーフィズム背景。透けて見える領域のクリックで記事を閉じる。 */}
  <CloseOverlay />

  <div
    class="z-20 relative flex flex-col mx-auto mt-8 px-4 md:pl-16 md:pr-4 pb-16 w-[calc(100%-2rem)] max-w-[68rem] rounded-lg bg-[#f5f0e6] shadow-[0_0px_4px_0px_rgba(31,27,28,0.45)] prose transition-colors duration-500 dark:bg-[#0b1422] dark:shadow-[0_0px_3px_0px_rgba(0,0,0,0.6)] dark:prose-invert"
  >
    {/* 上端：封蝋の下半分／下端：封蝋の上半分。どちらもクリックで記事を閉じる。 */}
    <CloseSeal position="top" />
    <CloseSeal position="bottom" />
    <div class="invisible flex justify-end z-30 sticky top-0 pt-4">
      <CloseButton />
    </div>
    <div class="grid min-w-0 grid-cols-1 md:grid-cols-[minmax(0,1fr)_12rem]">
      <div class="min-w-0 font-zen-maru-gothic-medium overflow-x-visible">
        <h1
          class="mb-1 md:mb-3 text-lg sm:text-3xl md:text-4xl dark:text-[#cbd9ea]"
        >
          {data.title}
        </h1>
        <DateInfo data={data} class="text-xs sm:text-base" />
        <Toc headings={headings} variant="mobile" />
        <div class="post" set:html={html} />
      </div>
      <div class="hidden md:block w-full md:w-[12rem] pl-4">
        <Toc headings={headings} />
      </div>
    </div>
  </div>
  <ArticleInteractions />
</Layout>
