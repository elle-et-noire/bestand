---
import Seal from "./Seal.astro";

/**
 * モーダル枠の上端／下端にまたがって描く封蝋の半円。クリックすると記事を閉じて
 * トップ（一覧）へ戻る（封を切って閉じる、というメタファ）。視覚上の閉じる手段は
 * CloseButton（×）が担うため、こちらは aria-hidden の補助。
 */
interface Props {
  position: "top" | "bottom";
}
const { position } = Astro.props;
const isTop = position === "top";
const base = import.meta.env.BASE_URL;
---

<a
  href={base}
  aria-hidden="true"
  tabindex="-1"
  class:list={[
    "group block absolute left-1/2 z-40 h-8 w-12 -translate-x-1/2 overflow-hidden cursor-pointer",
    isTop ? "top-0" : "bottom-0",
  ]}
>
  {/* 封蝋の中心を窓の縁に合わせる → 直径が縁に flush し半分が出る。 */}
  <Seal
    highlight
    class={`absolute left-1/2 ${isTop ? "-top-[1.125rem]" : "-bottom-[1.125rem]"} size-9 -translate-x-1/2`}
  />
</a>
