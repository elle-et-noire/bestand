---
import ThemeToggle from "./ThemeToggle.astro";
import { withBase } from "../../lib/base";

// 背景の「目玉」パターンは scripts/generate-bg.mjs がビルド前に
// public/bg-retro.svg / public/bg-dark.svg として生成する（固定シードで決定論的）。
// ここではそれらを CSS background-image として参照するだけ。data URI の
// 全ページインライン（2 テーマで約 45KB／遷移ごとに再取得）をやめ、ブラウザの
// キャッシュに載せて HTML 本体も軽くする。
const retroImage = `url('${withBase("bg-retro.svg")}')`;
const darkImage = `url('${withBase("bg-dark.svg")}')`;
---

{/* テーマ切り替えボタン */}
<ThemeToggle />

{/* 最背面の背景レイヤー。両テーマ分を出力し、<html> の dark クラスに応じて Tailwind の
    dark: バリアントが display で出し分ける。inline script が描画前にクラスを付けるため、
    ちらつかずに正しいテーマで表示される。 */}
<div
  style={{ backgroundImage: retroImage, backgroundRepeat: "repeat" }}
  class="fixed inset-0 -z-50 w-full h-full bg-[#1f1b1c] dark:hidden"
>
</div>
<div
  style={{ backgroundImage: darkImage, backgroundRepeat: "repeat" }}
  class="fixed inset-0 -z-50 w-full h-full hidden bg-[#02050a] dark:block"
>
</div>
