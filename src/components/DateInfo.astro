---
import type { PostFrontmatter } from "@lib/post";

interface Props {
  data: PostFrontmatter;
  class?: string;
}
const { data, class: className = "" } = Astro.props;

const toDateString = (value: string) => new Date(value).toISOString().split("T")[0];
const publish = toDateString(data.publish);
const lastUpdate = data.lastUpdate ? toDateString(data.lastUpdate) : null;
---

<div
  class:list={[
    "flex flex-wrap gap-x-2 gap-y-1 justify-start font-zen-maru-gothic-medium font-medium text-[#6f6152] dark:text-[#8aa0bb] italic",
    className,
  ]}
>
  <span class="inline-flex whitespace-nowrap"><span class="pr-1">投稿日</span>{publish}</span>
  {
    lastUpdate && (
      <span class="inline-flex whitespace-nowrap"><span class="pr-1">» 最終更新日</span>{lastUpdate}</span>
    )
  }
</div>
